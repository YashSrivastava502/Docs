trigger:
  branches:
    include:
      - master

pool:
  name: SelfHostedPool

variables:
  app_root: "/change_management_portal"
  release_dir: "/change_management_portal/releases"

steps:

- checkout: self

- task: NodeTool@0
  inputs:
    versionSpec: '18.x'

# 1️⃣ Install dependencies
- script: |
    npm install
  displayName: Install dependencies

# 2️⃣ Build Next.js
- script: |
    npm run build
  displayName: Build Next.js

# 3️⃣ Create versioned release
- script: |
    BUILD_ID=$(Build.BuildId)

    mkdir -p $(release_dir)/build_$BUILD_ID

    rsync -av --delete ./ $(release_dir)/build_$BUILD_ID/
  displayName: Create release

# 4️⃣ Install production dependencies
- script: |
    cd $(release_dir)/build_$(Build.BuildId)
    npm install --production
  displayName: Install production dependencies

# 5️⃣ Switch current symlink
- script: |
    ln -sfn $(release_dir)/build_$(Build.BuildId) $(app_root)/current
  displayName: Switch to new version

# 6️⃣ Copy .env file (IMPORTANT 🔥)
- script: |
    cp $(app_root)/.env $(app_root)/current/.env
  displayName: Copy .env to current

# 7️⃣ Start or Reload PM2
- script: |

    cd $(app_root)/current

    if pm2 list | grep change-portal; then
        echo "PM2 process exists → Reloading"
        pm2 reload change-portal
    else
        echo "PM2 process not found → Starting first time"
        pm2 start npm --name "change-portal" -- start
    fi

    pm2 save

  displayName: Start/Reload PM2

# 8️⃣ Health Check
- script: |

    sleep 10

    STATUS=$(curl -o /dev/null -s -w "%{http_code}" http://localhost:3000)

    if [ "$STATUS" -ne 200 ]; then
        echo "Health check failed ❌"
        pm2 logs --lines 50
        exit 1
    fi

    echo "Health check passed ✅"

  displayName: Health Check
